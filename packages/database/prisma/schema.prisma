generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")                     // pooled (PgBouncer) — used by app at runtime
  directUrl = env("DATABASE_URL_UNPOOLED")           // direct connection — required for migrations (Prisma)
}